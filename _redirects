# لوحة التحكم وصفحات العملاء — ملفات ثابتة (أولوية قبل أي قاعدة)
/admin/*    /admin/:splat    200
/client/*   /client/:splat   200
/admin      /admin/login     302

# الصفحات الديناميكية — يجب أن ترى المسار الأصلي حتى يعمل الـ middleware
# الـ middleware في Cloudflare Pages يعمل على المسار الأصلي قبل أي redirect
# لذا نُعيد index.html مع الحفاظ على المسار الأصلي (200 rewrite)
/article/*  /index.html  200
/project/*  /index.html  200
/service/*  /index.html  200

# صفحات Listing - SPA
/articles   /index.html  200
